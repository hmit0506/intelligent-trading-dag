# Environment Variables Example File
# Copy this file to .env and fill in your actual API keys
# Command: cp env.example .env

# ============================================
# Binance API Keys (REQUIRED for market data)
# ============================================
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# Note: For public data access, you may not need trading permissions
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_API_SECRET=your-binance-api-secret-here

# ============================================
# LLM Provider API Keys (Choose based on your provider)
# ============================================

# OpenAI (for GPT models)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Groq (for fast inference)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# OpenRouter (for multiple models)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Gemini
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic (for Claude models)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================
# Notes:
# ============================================
# 1. You only need to set the API keys for the LLM provider you plan to use
# 2. Binance API keys are required for fetching market data
# 3. For Ollama (local models), you don't need any API keys
# 4. Never commit your .env file to Git (it's in .gitignore)
# 5. Keep your API keys secure and never share them

